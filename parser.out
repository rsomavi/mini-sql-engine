Rule 4     select_list -> STAR
Rule 5     select_list -> column_list
Rule 6     column_list -> ID
Rule 7     column_list -> column_list COMMA ID
Rule 8     condition -> simple_condition
Rule 9     condition -> condition AND condition
Rule 10    condition -> condition OR condition
Rule 11    simple_condition -> ID comparator value
Rule 12    comparator -> EQUAL
Rule 13    comparator -> GT
Rule 14    comparator -> LT
Rule 15    comparator -> GE
Rule 16    comparator -> LE
Rule 17    value -> NUMBER
Rule 18    value -> STRING

